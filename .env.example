# Configuración de Firebase (Firebase Console > Project settings > Your apps > Web app).
# Copia este archivo a .env.local y rellena los valores. NO subas .env.local al repo.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
